{
  "name": "diva-player",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all:ps1": "powershell -ExecutionPolicy Bypass -NoProfile -File ./scripts/start-dev.ps1",
    "dev:all:sh": "sh ./scripts/start-dev.sh",
    "build": "tsc -b && vite build",
    "build:cloudflare": "tsc -b && vite build --base=/",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration:sbc": "node scripts/test-sbc-integration.mjs",
    "test:e2e:sbc": "node scripts/test-sbc-e2e.mjs",
    "test:e2e:recommendation-debug": "node scripts/test-recommendation-debug-e2e.mjs",
    "test:e2e:trending-seeds": "node scripts/test-trending-seeds.mjs",
    "test:cloudflare-proxy": "node scripts/test-cloudflare-pages-proxy.mjs",
    "test:e2e:pages-nico": "node scripts/test-pages-nico-e2e.mjs",
    "analyze:surge-quality": "node scripts/analyze-surge-quality.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-virtual": "^3.13.24",
    "idb-keyval": "^6.2.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/youtube": "^0.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "puppeteer": "^25.1.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.10"
  }
}
